# Root Docker Compose environment for local and hosted deployments.
# Copy this file to `.env` at the repository root and adjust values
# before running `docker-compose up` outside the default localhost setup.

POSTGRES_DB=nakama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

NAKAMA_NAME=tictactoe-nakama
NAKAMA_HTTP_PORT=7350
NAKAMA_GRPC_PORT=7349
NAKAMA_CONSOLE_PORT=7351
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=admin123
NAKAMA_SERVER_KEY=defaultkey
NAKAMA_RUNTIME_HTTP_KEY=change-me-runtime-http-key
NAKAMA_SESSION_ENCRYPTION_KEY=change-me-session-encryption-key
NAKAMA_SESSION_REFRESH_ENCRYPTION_KEY=change-me-refresh-encryption-key
NAKAMA_SESSION_TOKEN_EXPIRY_SEC=7200
NAKAMA_SESSION_REFRESH_TOKEN_EXPIRY_SEC=86400

FRONTEND_PORT=3000
VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_USE_SSL=false
VITE_NAKAMA_SERVER_KEY=defaultkey
